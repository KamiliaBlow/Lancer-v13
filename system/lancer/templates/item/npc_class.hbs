<form class="{{cssClass}} lancer-sheet" autocomplete="off">
  {{!-- Sheet Header --}}
  <header class="sheet-header card clipped-bot">
    <h1 class="name"><input class="lancer-input header-field" name="name" type="text" value="{{item.name}}" placeholder="{{localize "lancer.placeholder.name"}}"/></h1>
    {{{ ref-portrait-img item.img "img" system.}}}
    <div class="header-details">
      <input class="header-field" style="margin: 8px 2%; width: 96%;" name="system.role" type="text" value="{{item.system.role}}" placeholder="{{localize "lancer.placeholder.npc_class_role"}}"/>
    </div>
  </header>

  {{!-- Description --}}
  {{{textarea-card (localize "lancer.stat-names.description") "system.flavor"}}}
  {{{textarea-card (localize "lancer.stat-names.tactics") "system.tactics"}}}

  {{!-- Frame Stats --}}
  <div class="card clipped wraprow quadruple">
    <div class="wraprow quadruple">
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.hull") "system.base_stats" "hull"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.agi") "system.base_stats" "agi"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.sys") "system.base_stats" "sys"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.eng") "system.base_stats" "eng"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.armor") "system.base_stats" "armor"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.hp") "system.base_stats" "hp"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.structure") "system.base_stats" "structure"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.stress") "system.base_stats" "stress"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.evasion") "system.base_stats" "evasion"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.e-defense") "system.base_stats" "edef"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.heat") "system.base_stats" "heatcap"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.speed") "system.base_stats" "speed"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.activations") "system.base_stats" "activations"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.sensors") "system.base_stats" "sensor_range"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.save") "system.base_stats" "save"}}}
      {{{npc-clicker-statblock-card (localize "lancer.stat-names.size") "system.base_stats" "size"}}}
    </div>
  </div>

  <div class="flexcol card clipped-top lancer-border-primary" style="margin: 10px;">
    <div class="lancer-header lancer-primary major">
      <span class="major">{{localize "lancer.stat-names.base-features"}}</span>
    </div>

    {{{lid-item-list "system.base_features" base_features "npc_feature"}}}
  </div>

  <div class="flexcol card clipped-top lancer-border-primary" style="margin: 10px;">
    <div class="lancer-header lancer-primary major">
      <span class="major">{{localize "lancer.stat-names.optional-features"}}</span>
    </div>

    {{{lid-item-list "system.optional_features" optional_features "npc_feature"}}}
  </div>

</form>
